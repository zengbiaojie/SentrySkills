{
  "version": "1.0.0",
  "last_updated": "2026-03-25",
  "rule_categories": {
    "ai_model": {
      "description": "AI/LLM specific attack detection",
      "rules": [
        {
          "name": "llm_prompt_injection",
          "enabled": true,
          "severity": "high",
          "phase": [
            "preflight",
            "runtime"
          ],
          "patterns": [
            "ignore previous instructions",
            "ignore all instructions",
            "disregard previous",
            "forget everything",
            "new instructions:",
            "override protocol",
            "system prompt:",
            "jailbreak",
            "developer mode",
            "act as:",
            "pretend you are",
            "roleplay as"
          ],
          "description": "Detects prompt injection and jailbreak attempts"
        },
        {
          "name": "llm_indirect_prompt_leak",
          "enabled": true,
          "severity": "medium",
          "phase": [
            "preflight",
            "runtime"
          ],
          "patterns": [
            "repeat your instructions",
            "show your prompt",
            "print your system prompt",
            "output your instructions",
            "what are your guidelines",
            "reveal your programming"
          ],
          "description": "Detects attempts to extract system prompts"
        },
        {
          "name": "llm_code_interpretation_abuse",
          "enabled": true,
          "severity": "high",
          "phase": [
            "runtime"
          ],
          "patterns": [
            "execute this code",
            "run this command",
            "eval(",
            "exec(",
            "__import__",
            "subprocess",
            "os.system",
            "commands.getoutput"
          ],
          "description": "Detects attempts to abuse code execution capabilities"
        },
        {
          "name": "llm_refusal_suppression",
          "enabled": true,
          "severity": "medium",
          "phase": [
            "preflight",
            "runtime"
          ],
          "patterns": [
            "ignore safety",
            "bypass filter",
            "ignore restrictions",
            "no matter what",
            "without ethics",
            "ignore guidelines",
            "override safety"
          ],
          "description": "Detects attempts to suppress safety refusals"
        }
      ]
    },
    "web_security": {
      "description": "Web application security vulnerabilities",
      "rules": [
        {
          "name": "command_injection_basic",
          "enabled": true,
          "severity": "critical",
          "phase": [
            "preflight",
            "runtime",
            "output"
          ],
          "patterns": [
            "; cat",
            "; ls",
            "; pwd",
            "| nc",
            "| netcat",
            "; wget",
            "| curl",
            "; curl",
            "; rm -rf",
            "&& curl",
            "|| curl",
            "; nslookup",
            "; whoami"
          ],
          "description": "Detects basic command injection patterns"
        },
        {
          "name": "ssti_detection",
          "enabled": true,
          "severity": "high",
          "phase": [
            "preflight",
            "runtime"
          ],
          "patterns": [
            "{{config}}",
            "{{7*7}}",
            "{{''.__class__}}",
            "${7*7}",
            "#{7*7}",
            "{{_self.env}}",
            "{{request.application}}",
            "{{''.__class__.__mro__}}"
          ],
          "description": "Detects Server-Side Template Injection attempts"
        },
        {
          "name": "path_traversal_advanced",
          "enabled": true,
          "severity": "high",
          "phase": [
            "preflight",
            "runtime"
          ],
          "patterns": [
            "../etc/passwd",
            "..\\..\\..\\windows",
            "%2e%2e%2f",
            "....//",
            "....\\\\",
            "/proc/self/environ",
            "c:\\windows\\system32",
            "/etc/shadow"
          ],
          "description": "Detects advanced path traversal attempts"
        },
        {
          "name": "log4j_detection",
          "enabled": true,
          "severity": "critical",
          "phase": [
            "preflight",
            "runtime"
          ],
          "patterns": [
            "${jndi:",
            "${lower:jndi:}",
            "${upper:jndi:}",
            "${::-jndi:}",
            "${date:}",
            "${env:",
            "${sys:",
            "${bundle:",
            "${ctx:"
          ],
          "description": "Detects Log4Shell and JNDI injection patterns"
        },
        {
          "name": "graphql_injection",
          "enabled": true,
          "severity": "medium",
          "phase": [
            "preflight",
            "runtime"
          ],
          "patterns": [
            "{__schema",
            "{__type",
            "fragment",
            "mutation{",
            "mutation Create",
            "IntrospectionQuery",
            "batch{"
          ],
          "description": "Detects GraphQL injection and introspection attempts"
        }
      ]
    },
    "data_leak": {
      "description": "Sensitive data and credential leakage detection",
      "rules": [
        {
          "name": "ssh_private_key",
          "enabled": true,
          "severity": "critical",
          "phase": [
            "preflight",
            "runtime",
            "output"
          ],
          "patterns": [
            "-----BEGIN RSA PRIVATE KEY-----",
            "-----BEGIN DSA PRIVATE KEY-----",
            "-----BEGIN EC PRIVATE KEY-----",
            "-----BEGIN OPENSSH PRIVATE KEY-----",
            "-----BEGIN PRIVATE KEY-----"
          ],
          "description": "Detects SSH private key exposure"
        },
        {
          "name": "aws_credentials",
          "enabled": true,
          "severity": "critical",
          "phase": [
            "preflight",
            "runtime",
            "output"
          ],
          "patterns": [
            "AKIA[0-9A-Z]{16}",
            "(?i)aws_access_key_id\\s*[:=]\\s*[A-Z0-9]{20}",
            "(?i)aws_secret_access_key\\s*[:=]\\s*[A-Za-z0-9/+=]{40}"
          ],
          "description": "Detects AWS credential exposure"
        },
        {
          "name": "github_token",
          "enabled": true,
          "severity": "critical",
          "phase": [
            "preflight",
            "runtime",
            "output"
          ],
          "patterns": [
            "ghp_[a-zA-Z0-9]{36}",
            "gho_[a-zA-Z0-9]{36}",
            "ghu_[a-zA-Z0-9]{36}",
            "ghs_[a-zA-Z0-9]{36}",
            "ghr_[a-zA-Z0-9]{36}"
          ],
          "description": "Detects GitHub token exposure"
        },
        {
          "name": "slack_token",
          "enabled": true,
          "severity": "high",
          "phase": [
            "preflight",
            "runtime",
            "output"
          ],
          "patterns": [
            "xoxb-[0-9]{10}-[0-9]{10}-[a-zA-Z0-9]{24}",
            "xoxp-[0-9]{10}-[0-9]{10}-[0-9]{10}-[a-zA-Z0-9]{24}"
          ],
          "description": "Detects Slack token exposure"
        },
        {
          "name": "api_key_generic",
          "enabled": true,
          "severity": "high",
          "phase": [
            "preflight",
            "runtime",
            "output"
          ],
          "patterns": [
            "(?i)api[_-]?key\\s*[:=]\\s*[\"']?[a-zA-Z0-9_]{20,}",
            "(?i)apikey\\s*[:=]\\s*[\"']?[a-zA-Z0-9_]{20,}",
            "(?i)secret[_-]?key\\s*[:=]\\s*[\"']?[a-zA-Z0-9_]{20,}"
          ],
          "description": "Detects generic API key patterns"
        },
        {
          "name": "database_connection_string",
          "enabled": true,
          "severity": "high",
          "phase": [
            "preflight",
            "runtime",
            "output"
          ],
          "patterns": [
            "(?i)mongodb\\+srv://.+@.+",
            "(?i)redis://.+@.+",
            "(?i)postgresql://.+@.+",
            "(?i)mysql://.+@.+",
            "(?i)postgres://.+@.+",
            "Data Source=.+;Password",
            "Server=.+;Database=.+;Uid"
          ],
          "description": "Detects database connection string exposure"
        },
        {
          "name": "private_ip_address",
          "enabled": true,
          "severity": "medium",
          "phase": [
            "preflight",
            "runtime",
            "output"
          ],
          "patterns": [
            "\\b10\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\b",
            "\\b172\\.(1[6-9]|2[0-9]|3[0-1])\\.[0-9]{1,3}\\.[0-9]{1,3}\\b",
            "\\b192\\.168\\.[0-9]{1,3}\\.[0-9]{1,3}\\b",
            "\\b127\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\b"
          ],
          "description": "Detects private IP address exposure"
        },
        {
          "name": "certificate_base64",
          "enabled": true,
          "severity": "high",
          "phase": [
            "preflight",
            "runtime",
            "output"
          ],
          "patterns": [
            "-----BEGIN CERTIFICATE-----",
            "MII[a-zA-Z0-9/+]{100,}=",
            "MIIC[a-zA-Z0-9/+]{100,}="
          ],
          "description": "Detects certificate exposure"
        }
      ]
    },
    "code_security": {
      "description": "Code security best practices violations",
      "rules": [
        {
          "name": "hardcoded_secrets",
          "enabled": true,
          "severity": "medium",
          "phase": [
            "output"
          ],
          "patterns": [
            "password\\s*=\\s*[\"'][^\"']{8,}[\"']",
            "secret\\s*=\\s*[\"'][^\"']{8,}[\"']",
            "api_key\\s*=\\s*[\"'][^\"']{8,}[\"']",
            "token\\s*=\\s*[\"'][^\"']{8,}[\"']"
          ],
          "description": "Detects hardcoded secrets in code"
        },
        {
          "name": "weak_crypto",
          "enabled": true,
          "severity": "medium",
          "phase": [
            "output"
          ],
          "patterns": [
            "md5\\(",
            "sha1\\(",
            "DES\\(",
            "RC4\\(",
            "\\.(encrypt|decrypt)\\s*\\(\\s*['\"]ecb",
            "\\.(encrypt|decrypt)\\s*\\(\\s*['\"]none"
          ],
          "description": "Detects weak cryptographic algorithms"
        },
        {
          "name": "sql_without_param",
          "enabled": true,
          "severity": "low",
          "phase": [
            "output"
          ],
          "patterns": [
            "execute\\s*\\(.+\\+.+\\)",
            "query\\s*\\(.+%s.+.+\\)",
            "raw\\s*\\(.+SELECT.+\\+.+\\)",
            "\\$wpdb->query\\s*\\(.+\\$"
          ],
          "description": "Detects potential SQL injection via concatenation"
        },
        {
          "name": "eval_usage",
          "enabled": true,
          "severity": "medium",
          "phase": [
            "output"
          ],
          "patterns": [
            "eval\\s*\\(",
            "exec\\s*\\(",
            "Function\\s*\\(",
            "setTimeout\\s*\\(.*string.*\\)",
            "setInterval\\s*\\(.*string.*\\)"
          ],
          "description": "Detects dangerous eval/exec usage"
        },
        {
          "name": "debug_code",
          "enabled": true,
          "severity": "low",
          "phase": [
            "output"
          ],
          "patterns": [
            "console\\.log\\s*\\(",
            "console\\.debug\\s*\\(",
            "print\\s*\\(.+password|secret|key",
            "pprint\\s*\\(",
            "var_dump\\s*\\(",
            "debugger"
          ],
          "description": "Detects debug statements that may leak data"
        },
        {
          "name": "unsafe_random",
          "enabled": true,
          "severity": "low",
          "phase": [
            "output"
          ],
          "patterns": [
            "Math\\.random\\(\\)",
            "rand\\(\\)",
            "random\\.random\\(\\)"
          ],
          "description": "Detects weak random number generation"
        },
        {
          "name": "file_inclusion",
          "enabled": true,
          "severity": "high",
          "phase": [
            "output"
          ],
          "patterns": [
            "include\\s*\\(\\s*\\$",
            "require\\s*\\(\\s*\\$",
            "include_once\\s*\\(\\s*\\$",
            "require_once\\s*\\(\\s*\\$"
          ],
          "description": "Detects potentially unsafe file inclusion"
        }
      ]
    }
  },
  "metadata": {
    "total_rules": 24,
    "enabled_rules": 24,
    "phases": {
      "preflight": 20,
      "runtime": 18,
      "output": 13
    }
  }
}