{
  "_comment": "Expanded runtime policy with extended risk detection capabilities - Phase 1",
  "version": "2.0",
  "sensitive_event_types": [
    "read_secret",
    "read_credential",
    "read_private_pii",
    "read_key_material",
    "read_database_credential",
    "read_auth_token",
    "read_certificate",
    "read_network_info",
    "read_extended_pii",
    "read_config_secret"
  ],
  "sensitive_keywords": [
    "token",
    "password",
    "secret",
    "api_key",
    "credential",
    "private key",
    "id card",
    "phone number",
    "jwt",
    "oauth",
    "bearer token",
    "refresh token",
    "access token",
    "session token",
    "connection string",
    "database url",
    "mongodb uri",
    "redis connection",
    "jdbc url",
    "ssl certificate",
    "tls certificate",
    "certificate chain",
    "internal ip",
    "private ip",
    "server address",
    "api endpoint",
    "service url",
    "webhook url",
    "email address",
    "credit card",
    "bank account",
    "social security",
    "passport number",
    "home address",
    "medical record",
    "environment variable",
    "config key",
    "deployment key",
    "encryption key",
    "signing key"
  ],
  "explicit_disclosure_phrases": [
    "output token",
    "output password",
    "print token",
    "print password",
    "show jwt",
    "display api key",
    "reveal secret",
    "dump database",
    "export credentials",
    "show certificate",
    "display connection string"
  ],
  "implicit_disclosure_phrases": [
    "explain key fields and values",
    "repeat full configuration",
    "write out as-is",
    "show me the value",
    "include actual values",
    "display config file",
    "show .env contents",
    "list environment variables",
    "output deployment config"
  ],
  "explanation_leakage_phrases": [
    "explain purpose and give values",
    "list example values when explaining",
    "for explanation include exact values",
    "for demo include real data",
    "show actual token in example",
    "use real password for illustration"
  ],
  "config_disclosure_phrases": [
    "show .env file",
    "display config",
    "list environment variables",
    "output deployment config",
    "show secrets",
    "reveal configuration",
    "dump settings"
  ],
  "database_leak_phrases": [
    "show user records",
    "list all passwords",
    "dump database",
    "export user data",
    "query sensitive data",
    "display user table",
    "reveal customer data"
  ],
  "high_risk_actions": [
    "execute_command",
    "write_file",
    "batch_modify",
    "network_call",
    "delete_file",
    "delete_directory",
    "remove_data",
    "drop_table",
    "truncate_database",
    "database_query",
    "execute_sql",
    "migrate_database",
    "modify_schema",
    "send_email",
    "send_message",
    "post_to_slack",
    "webhook_call",
    "notify_external",
    "external_api_call",
    "third_party_service",
    "api_request",
    "graphql_query",
    "deploy_to_production",
    "restart_service",
    "modify_load_balancer",
    "change_dns",
    "update_firewall",
    "build_container",
    "deploy_container",
    "kubectl_apply",
    "docker_run",
    "helm_install"
  ],
  "critical_actions": [
    "delete_database",
    "deploy_to_production",
    "modify_firewall",
    "change_dns",
    "execute_system_command",
    "drop_table",
    "truncate_database"
  ],
  "retry_threshold_downgrade": 3,
  "single_source_types": [
    "tool_single_source"
  ],
  "leak_patterns": [
    "(?i)(api[_-]?key|token|password|secret)\\s*[:=]\\s*[^\\s,;]+",
    "(?i)-----BEGIN (RSA|EC|DSA|OPENSSH) PRIVATE KEY-----",
    "\\b\\d{17}[0-9Xx]\\b",
    "eyJ[a-zA-Z0-9_-]+\\.[a-zA-Z0-9_-]+\\.[a-zA-Z0-9_-]+",
    "(?i)(mongodb(\\+srv)?://|mysql://|postgres://|redis://)[^\\s:@]+:[^\\s@]+@",
    "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b",
    "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b",
    "\\b(?:[0-9a-fA-F]{1,4}:){7}[0-9a-fA-F]{1,4}\\b",
    "\\b\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}\\b",
    "https?://[^\\s<>\"']+|/[a-zA-Z0-9_-]+/api/[^\\s<>\"']*",
    "%[A-Z_]+%|\\${[A-Z_]+}",
    "(?i)jdbc:\\w+://[^\\s:]+:[^\\s@]+@",
    "(?i)bearer\\s+[a-zA-Z0-9._~+/=-]+",
    "(?i)ssh-rsa\\s+[a-zA-Z0-9+/=]+",
    "(?i)-----BEGIN\\s+(CERTIFICATE|PUBLIC KEY)-----"
  ],
  "force_uncertainty_prefix": "Conclusion uncertain based on single tool source.",
  "block_on_highly_sensitive_leak": true,
  "redaction_replacements": {
    "credential": "(?i)(api[_-]?key|token|password|secret)\\s*[:=]\\s*([^\\s,;]+)",
    "id": "\\b\\d{17}[0-9Xx]\\b",
    "private_key": "-----BEGIN (RSA|EC|DSA|OPENSSH) PRIVATE KEY-----",
    "jwt": "eyJ[a-zA-Z0-9_-]+\\.[a-zA-Z0-9_-]+\\.[a-zA-Z0-9_-]+",
    "email": "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b",
    "ip": "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b",
    "credit_card": "\\b\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}\\b",
    "database_url": "(?i)(mongodb\\+?srv://|mysql://|postgres://|redis://)[^\\s:@]+:[^\\s@]+@",
    "env_var": "%[A-Z_]+%|\\${[A-Z_]+}",
    "certificate": "(?i)-----BEGIN\\s+(CERTIFICATE|PUBLIC KEY)-----"
  },
  "residual_leak_patterns": [
    "(?i)(api[_-]?key|token|password|secret)\\s*[:=]\\s*(?!\\[REDACTED\\])[^\\s,;]+",
    "(?i)-----BEGIN (RSA|EC|DSA|OPENSSH) PRIVATE KEY-----",
    "\\b\\d{17}[0-9Xx]\\b",
    "(?!\\[REDACTED\\])eyJ[a-zA-Z0-9_-]+\\.[a-zA-Z0-9_-]+\\.[a-zA-Z0-9_-]+",
    "(?i)(mongodb(\\+srv)?://|mysql://|postgres://|redis://)[^\\s:@]+:(?!\\[REDACTED\\])[^\\s@]+@",
    "(?!\\[REDACTED\\])\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b",
    "(?!\\[REDACTED\\]|127\\.0\\.0\\.1|localhost)\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b",
    "(?!\\[REDACTED\\])\\b\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}\\b",
    "(?i)jdbc:\\w+://[^\\s:]+:(?!\\[REDACTED\\])[^\\s@]+@",
    "(?i)bearer\\s+(?!\\[REDACTED\\])[a-zA-Z0-9._~+/=-]+",
    "(?i)-----BEGIN\\s+(CERTIFICATE|PUBLIC KEY)-----[^-]+-----END"
  ],
  "attack_detection": {
    "enabled": true,
    "sql_injection_patterns": [
      "(?i)('.*=.*|;.*drop|;.*delete|;.*insert|union\\s+.*select|1\\s*=\\s*1)",
      "(?i)(\\bor\\b\\s+\\d+\\s*=\\s*\\d+\\s*\\bor\\b|\\band\\b\\s*\\d+\\s*=\\s*\\d+)",
      "(?i)(exec|execute)\\s*\\(|xp_cmdshell"
    ],
    "command_injection_patterns": [
      "[;&|]\\s*\\w+\\s*",
      "\\$\\([^)]+\\)",
      "`[^`]+`",
      "\\|[^|]*\\|[a-z]+"
    ],
    "path_traversal_patterns": [
      "\\.\\./",
      "\\.\\.\\\\",
      "%2e%2e",
      "\\.[%2f|%5c]",
      "~%2f|%2e%2e"
    ]
  },
  "context_awareness": {
    "enabled": true,
    "environment_keywords": {
      "production": ["prod", "production", "live", "main"],
      "staging": ["staging", "stage", "uat"],
      "development": ["dev", "development", "local", "test"]
    },
    "risk_multipliers": {
      "production": 2.0,
      "staging": 1.5,
      "development": 1.0
    }
  },
  "single_source_disclosure_title": "Source Disclaimer (Single Tool Source)",
  "single_source_missing_hint": "Source information missing"
}
