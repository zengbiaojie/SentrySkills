{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trinityguard-self-guard/audit_record.schema.json",
  "title": "Self Guard Audit Record (Legacy)",
  "description": "Legacy single-record schema. New integrations should use guard_event.schema.json with JSONL events.",
  "type": "object",
  "required": [
    "session_id",
    "trigger_reasons",
    "preflight",
    "runtime",
    "output_guard",
    "final_action"
  ],
  "properties": {
    "session_id": {"type": "string"},
    "trigger_reasons": {
      "type": "array",
      "items": {"type": "string"}
    },
    "preflight": {
      "type": "object",
      "required": ["sensitivity_state", "preflight_decision"],
      "properties": {
        "risk_summary": {"type": "array", "items": {"type": "string"}},
        "sensitivity_state": {"type": "string", "enum": ["normal", "sensitive", "highly_sensitive"]},
        "allowed_actions": {"type": "array", "items": {"type": "string"}},
        "blocked_actions": {"type": "array", "items": {"type": "string"}},
        "verification_requirements": {"type": "array", "items": {"type": "string"}},
        "preflight_decision": {"type": "string", "enum": ["allow", "downgrade", "block"]}
      }
    },
    "runtime": {
      "type": "object",
      "required": ["runtime_decision"],
      "properties": {
        "runtime_events": {"type": "array", "items": {"type": "object"}},
        "alerts": {"type": "array", "items": {"type": "object"}},
        "suggested_actions": {"type": "array", "items": {"type": "string"}},
        "trust_annotations": {"type": "array", "items": {"type": "object"}},
        "runtime_decision": {"type": "string", "enum": ["continue", "downgrade", "stop"]}
      }
    },
    "output_guard": {
      "type": "object",
      "required": ["leakage_detected", "redaction_applied", "confidence_level", "safe_response", "output_decision"],
      "properties": {
        "leakage_detected": {"type": "boolean"},
        "redaction_applied": {"type": "boolean"},
        "confidence_level": {"type": "string", "enum": ["low", "medium", "high"]},
        "safe_response": {"type": "string"},
        "output_decision": {"type": "string", "enum": ["allow", "downgrade", "block"]}
      }
    },
    "final_action": {"type": "string", "enum": ["allow", "downgrade", "block"]},
    "residual_risks": {"type": "array", "items": {"type": "string"}},
    "audit_notes": {"type": "array", "items": {"type": "string"}}
  }
}
